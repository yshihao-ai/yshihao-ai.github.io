@inproceedings{yang2026hycora,
  selected = {true},
  title = {HyCoRA: Hyper-Contrastive Role-Adaptive Learning for Role-Playing},
  author = {Shihao Yang# and Zhicong Lu# and Yong Yang# and Bo Lv and Yang Shen and Nayu Liu*},
  year = {2026},
  month = jan,
  booktitle = {Proceedings of the AAAI Conference on Artificial Intelligence},
  note = {Accepted to AAAI 2026},
  venue = {AAAI 2026},
  doi = {10.48550/arXiv.2511.08017},
  url = {https://arxiv.org/abs/2511.08017},
  code = {https://github.com/yshihao-ai/HyCoRA},
  preview = {hycora.jpg},
  category = {first-author},
  abstract = {Multi-character role-playing requires language models to express distinct role-specific traits while preserving shared linguistic competence. HyCoRA introduces a Hyper-Half LoRA structure in which the role-specific matrix is generated dynamically by a lightweight hyper-network, while a shared matrix captures common language knowledge. A hyper-contrastive learning objective further improves role discrimination by aligning role embeddings with their own responses and separating them from others.},
  description = {A role-adaptive framework for multi-character role-playing that combines Hyper-Half LoRA with hyper-contrastive learning.},
  keywords = {Large Language Models, Role-Playing, Parameter-Efficient Fine-Tuning, Hypernetworks}
}

@inproceedings{yu2026ore,
  title = {Orthogonal Representation Editing: Decoupling Semantic Entanglement in Batch Knowledge Editing of LLMs},
  author = {Wenhao Yu and Zhicong Lu and Bo Lv and Fangyin Ma and Kaiwen Wei and Shihao Yang and Nayu Liu},
  year = {2026},
  month = jun,
  booktitle = {Findings of the Association for Computational Linguistics: ACL 2026},
  note = {Accepted to Findings of ACL 2026},
  venue = {ACL 2026 Findings},
  doi = {10.48550/arXiv.2606.22627},
  url = {https://arxiv.org/abs/2606.22627},
  code = {https://github.com/YVVH/ORE},
  category = {participating},
  abstract = {Knowledge editing aims to efficiently update factual information in large language models without full retraining, but existing methods still suffer from performance degradation in batch settings. Orthogonal Representation Editing decouples semantic entanglement by constructing a general semantic subspace, enforcing orthogonal constraints on edit vectors, and introducing a gated non-linear representation head for adaptive editing locations and precise knowledge injection.},
  description = {A batch knowledge editing method for LLMs that reduces semantic entanglement through orthogonal representation constraints.},
  keywords = {Knowledge Editing, Large Language Models, Representation Editing, Knowledge Graph}
}
